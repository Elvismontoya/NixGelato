# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE=eyJ...tu_service_role_key...

# JWT - usar una clave larga y aleatoria
JWT_SECRET=reemplaza_con_clave_segura_de_minimo_32_caracteres

# Bcrypt rounds (default 10)
BCRYPT_SALT_ROUNDS=10

# Puerto servidor
PORT=4000

# URL del frontend (para CORS)
FRONTEND_ORIGIN=https://nixgelato.vercel.app
